# ===== Core =====
ENV=development
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# ===== JWT (dev only, not used for Supabase auth) =====
JWT_SECRET=change_me_dev_only

# ===== Supabase =====
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=public_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=service_role_key_here

# ===== Storage =====
UPLOADS_BUCKET=edu-uploads
SIGNED_URL_EXPIRES_SECONDS=60

CLAMD_HOST: str = "clamav"
CLAMD_PORT: int = 3310

# ===== Retention =====
ASSIGNMENT_RETENTION_DAYS=180
AI_ARTIFACT_RETENTION_DAYS=30

# ===== AI Service =====
AI_SERVICE_PORT=8010
AI_SERVICE_SECRET=change_me_dev_only

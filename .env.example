# ---------- Shared ----------
ENV=development

# ---------- Backend ----------
BACKEND_PORT=8000
JWT_SECRET=change_me_dev_only
ALLOWED_ORIGINS=http://localhost:3000

# Supabase (backend-only secrets must NEVER go to frontend)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=public_anon_key_ok_to_expose_if_needed
SUPABASE_SERVICE_ROLE_KEY=service_role_secret_backend_only

# Storage bucket name
ASSIGNMENTS_BUCKET=assignments

# Retention
ASSIGNMENT_RETENTION_DAYS=180
AI_ARTIFACT_RETENTION_DAYS=30

# ---------- AI Service ----------
AI_SERVICE_PORT=8010
AI_SERVICE_SECRET=change_me_dev_only
AI_NO_EXTERNAL_BROWSING=true
AI_NO_CROSS_USER_ACCESS=true
